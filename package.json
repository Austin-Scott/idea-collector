    "ffmpeg-static": "^5.2.0",
    "lucide-vue-next": "^0.468.0",
    "multer": "^2.0.2",
    "openai": "^4.77.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "selfsigned": "^2.4.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.5",
    "@types/qrcode-terminal": "^0.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.12",
